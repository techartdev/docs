{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SCP2P Documentation",
  "colors": {
    "primary": "#3B82F6",
    "light": "#60A5FA",
    "dark": "#2563EB"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "architecture"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/quickstart",
              "guides/desktop-app"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/manifests",
              "concepts/dht",
              "concepts/transports"
            ]
          }
        ]
      },
      {
        "tab": "Protocol",
        "groups": [
          {
            "group": "Specification",
            "pages": [
              "protocol/overview",
              "protocol/handshake",
              "protocol/discovery",
              "protocol/communities",
              "protocol/content-transfer"
            ]
          }
        ]
      },
      {
        "tab": "API & CLI",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "reference/cli",
              "reference/core-api"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://scp2p.com/",
          "icon": "globe"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/scp2p",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://scp2p.com/"
      }
    ]
  },
  "contextual": {
    "options": [
     "copy",
     "view"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/scp2p",
      "github": "https://github.com/scp2p"
    }
  }
}
